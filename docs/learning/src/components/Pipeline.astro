---
// A presentational left-to-right flow of labeled stages with arrows between
// them, plus an optional dashed "feedback" leg for online/adaptive loops.
// Reused by the compression, context-mixing, and fast-weight pages (rule of
// two): the recurring "predict, then fold the truth back in" picture.
interface Step {
  label: string;
  sub?: string;
  accent?: "reference" | "fast_weight" | "transformer" | "free" | "accent";
}
interface Props {
  steps: Step[];
  /** dashed return-arrow caption, e.g. "after reveal: write (key→byte)". */
  feedback?: string;
}
const { steps, feedback } = Astro.props;
---

<div class="pipe" role="img" aria-label={steps.map((s) => s.label).join(" then ")}>
  <div class="pipe-row">
    {
      steps.map((s, i) => (
        <>
          <div class={`pipe-node${s.accent ? " accent-" + s.accent : ""}`}>
            <span class="pipe-node-label">{s.label}</span>
            {s.sub && <span class="pipe-node-sub">{s.sub}</span>}
          </div>
          {i < steps.length - 1 && <span class="pipe-arrow" aria-hidden="true">&rarr;</span>}
        </>
      ))
    }
  </div>
  {
    feedback && (
      <div class="pipe-feedback">
        <span class="pipe-feedback-arrow" aria-hidden="true">&#8630;</span>
        {feedback}
      </div>
    )
  }
</div>

<style>
  .pipe {
    margin: 1.7em 0;
    padding: 1.1rem 1rem 0.9rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background:
      repeating-linear-gradient(90deg, transparent, transparent 25px, var(--line-soft) 25px, var(--line-soft) 26px),
      var(--ink-1);
  }
  .pipe-row {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    justify-content: center;
    gap: 0.55rem;
  }
  .pipe-node {
    flex: 1 1 0;
    min-width: 6.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    justify-content: center;
    text-align: center;
    padding: 0.6rem 0.7rem;
    border: 1px solid var(--line);
    border-bottom: 2px solid var(--faint);
    border-radius: var(--radius);
    background: var(--ink-2);
  }
  .pipe-node-label {
    font-family: var(--font-display);
    font-size: 0.98rem;
    color: var(--paper);
    line-height: 1.2;
  }
  .pipe-node-sub {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    line-height: 1.3;
  }
  .pipe-arrow {
    align-self: center;
    color: var(--accent-deep);
    font-size: 1.3rem;
  }
  .accent-accent {
    border-bottom-color: var(--accent);
  }
  .accent-reference {
    border-bottom-color: var(--c-reference);
  }
  .accent-fast_weight {
    border-bottom-color: var(--c-fast);
  }
  .accent-transformer {
    border-bottom-color: var(--c-transformer);
  }
  .accent-free {
    border-bottom-color: var(--c-free);
  }
  .pipe-feedback {
    margin-top: 0.7rem;
    padding-top: 0.6rem;
    border-top: 1px dashed var(--line);
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--c-fast);
  }
  .pipe-feedback-arrow {
    margin-right: 0.4rem;
    font-size: 1rem;
  }
  @media (max-width: 560px) {
    .pipe-row {
      flex-direction: column;
    }
    .pipe-arrow {
      transform: rotate(90deg);
    }
  }
</style>
