---
// The index concept map: a hand-laid top-down DAG of the compendium, with
// clickable nodes — the navigational spine (no orphan pages). The concept DAG
// (goal → pillars → mechanisms + control) feeds the experiment log, and every
// individual experiment hangs off the log below in TWO phase rows so 13 leaves
// don't crowd: Space-B byte prediction on top, Space-C control + the finding
// beneath (hung off the left, beside the control concept). Negatives (candidates
// that were Pareto-hollow / killed / lost) get a dashed, muted border — failures
// are first-class data. A role-colour legend (incl. the new column_mix slate)
// sits bottom-right.
type Role =
  | "accent"
  | "reference"
  | "fast_weight"
  | "transformer"
  | "pc"
  | "warm"
  | "reservoir"
  | "chemotaxis"
  | "column_mix";
interface Node {
  id: string;
  x: number;
  y: number;
  w: number;
  label: string;
  role?: Role;
  href?: string;
}
const H = 46;
const nodes: Node[] = [
  { id: "goal", x: 470, y: 50, w: 240, label: "Goal: more learning per FLOP", role: "accent" },
  { id: "lpf", x: 156, y: 162, w: 188, label: "Loss-per-FLOP & scaling", href: "/concepts/loss-per-flop-and-scaling-laws" },
  { id: "cp", x: 470, y: 162, w: 198, label: "Compression = prediction", href: "/concepts/compression-equals-prediction" },
  { id: "s4", x: 786, y: 162, w: 180, label: "Source-(iv) advantage", href: "/concepts/source-iv-advantage" },
  { id: "preq", x: 300, y: 286, w: 184, label: "Prequential evaluation", href: "/concepts/prequential-evaluation" },
  { id: "cmix", x: 668, y: 306, w: 190, label: "Online context mixing", role: "reference", href: "/concepts/context-mixing" },
  { id: "fwm", x: 462, y: 414, w: 184, label: "Fast-weight memory", role: "fast_weight", href: "/concepts/fast-weight-memory" },
  { id: "pc", x: 780, y: 414, w: 170, label: "Predictive coding", role: "pc", href: "/concepts/predictive-coding" },
  { id: "warm", x: 652, y: 366, w: 150, label: "Online warm-start", role: "warm", href: "/concepts/online-warmup" },
  { id: "ctrl", x: 170, y: 432, w: 180, label: "In-context control", href: "/concepts/in-context-control" },
  { id: "exp", x: 462, y: 504, w: 156, label: "Experiment log", role: "accent", href: "/experiments" },
];
const byId = Object.fromEntries(nodes.map((n) => [n.id, n]));

interface Edge {
  from: string;
  to: string;
  dashed?: boolean;
}
const edges: Edge[] = [
  { from: "goal", to: "lpf" },
  { from: "goal", to: "cp" },
  { from: "goal", to: "s4" },
  { from: "lpf", to: "preq" },
  { from: "cp", to: "preq" },
  { from: "cp", to: "cmix" },
  { from: "s4", to: "cmix" },
  { from: "s4", to: "fwm" },
  { from: "preq", to: "fwm" },
  { from: "preq", to: "cmix" },
  { from: "fwm", to: "exp", dashed: true },
  { from: "cmix", to: "exp", dashed: true },
  { from: "preq", to: "exp", dashed: true },
  { from: "s4", to: "pc" },
  { from: "pc", to: "exp", dashed: true },
  { from: "cmix", to: "warm" },
  { from: "preq", to: "ctrl" },
  { from: "lpf", to: "ctrl" },
  { from: "warm", to: "fwm" },
  { from: "ctrl", to: "exp", dashed: true },
];

// Experiment leaves on two phase rows, every page reachable from the map. A
// `negative` leaf (candidate that was Pareto-hollow / killed / lost on its
// metric) gets a dashed, muted border. The Space-B byte experiments form the
// top row off the log trunk; the Space-C control rungs + the methodological
// finding form the bottom row, hung off the left (beside the control concept).
interface Leaf {
  id: string;
  label: string;
  role?: Role;
  negative?: boolean;
  href: string;
}
const byteRow: Leaf[] = [
  { id: "e01", label: "0.1 base", href: "/experiments/0.1-baseline-harness-smoke" },
  { id: "e02", label: "0.2 preq", href: "/experiments/0.2-prequential-baseline" },
  { id: "eref", label: "0.3 ref", role: "reference", href: "/experiments/context-mixing-reference" },
  { id: "ea1", label: "A.1 fast-wt", role: "fast_weight", negative: true, href: "/experiments/A.1-fast-weight-memory" },
  { id: "eb1", label: "B.1 PC", role: "pc", negative: true, href: "/experiments/B.1-surprise-gated-pc-refinement" },
  { id: "eb2", label: "B.2 warm", role: "warm", href: "/experiments/B.2-warmed-mixing" },
  { id: "eb3", label: "B.3 hashed", role: "warm", href: "/experiments/B.3-hashed-mix-full-corpus" },
  { id: "eb4", label: "B.4 delta", role: "fast_weight", href: "/experiments/B.4-delta-mix" },
  { id: "eb5", label: "B.5 column", role: "column_mix", negative: true, href: "/experiments/B.5-column-mix" },
];
const ctrlRow: Leaf[] = [
  { id: "ec1", label: "C.A.1 resv", role: "reservoir", negative: true, href: "/experiments/C.A.1-reservoir-control" },
  { id: "ec2", label: "C.A.2 chemo", role: "chemotaxis", href: "/experiments/C.A.2-chemotaxis-min-control" },
  { id: "ec3", label: "C.A.3 forage", role: "transformer", href: "/experiments/C.A.3-contingency-forage" },
  { id: "eff", label: "first find", role: "accent", href: "/experiments/first-finding-pareto" },
];

const LEAF_W = 84;
const TRUNK_X = byId.exp.x;
const CONN_X = 60;
const BYTE_BUS_Y = 552;
const BYTE_LEAF_Y = 596;
const CTRL_BUS_Y = 648;
const CTRL_LEAF_Y = 692;
const spread = (arr: Leaf[], x0: number, x1: number, busY: number, leafY: number) =>
  arr.map((l, i) => ({
    ...l,
    x: arr.length === 1 ? (x0 + x1) / 2 : x0 + ((x1 - x0) * i) / (arr.length - 1),
    busY,
    leafY,
  }));
const byteLeaves = spread(byteRow, 110, 900, BYTE_BUS_Y, BYTE_LEAF_Y);
const ctrlLeaves = spread(ctrlRow, 120, 400, CTRL_BUS_Y, CTRL_LEAF_Y);
const allLeaves = [...byteLeaves, ...ctrlLeaves];
const byteMaxX = byteLeaves[byteLeaves.length - 1].x;
const ctrlMaxX = ctrlLeaves[ctrlLeaves.length - 1].x;

// role-colour legend (covers every role drawn, incl. the new column_mix slate).
const legendRoles: { role: Role; label: string }[] = [
  { role: "reference", label: "reference · counts" },
  { role: "fast_weight", label: "fast-weight · delta" },
  { role: "warm", label: "online warm-start" },
  { role: "pc", label: "predictive coding" },
  { role: "reservoir", label: "reservoir" },
  { role: "chemotaxis", label: "chemotaxis" },
  { role: "column_mix", label: "column_mix" },
  { role: "transformer", label: "transformer bar" },
];
const LG_X = 470;
const LG_Y = 626;

function endpoints(a: Node, b: Node) {
  const dx = b.x - a.x;
  const dy = b.y - a.y;
  if (Math.abs(dy) >= Math.abs(dx)) {
    return { x1: a.x, y1: a.y + H / 2, x2: b.x, y2: b.y - H / 2 };
  }
  const s = Math.sign(dx);
  return { x1: a.x + (s * a.w) / 2, y1: a.y, x2: b.x - (s * b.w) / 2, y2: b.y };
}

// Smooth cubic-Bézier edge: control points offset along the dominant axis so the
// curve departs/arrives perpendicular to the node edge (clean tangents, no kinks);
// Δ = 0.4·span keeps the bow gentle so curves don't lap into other boxes.
function edgePath(a: Node, b: Node) {
  const { x1, y1, x2, y2 } = endpoints(a, b);
  if (Math.abs(b.y - a.y) >= Math.abs(b.x - a.x)) {
    const d = 0.4 * (y2 - y1);
    return `M ${x1} ${y1} C ${x1} ${y1 + d} ${x2} ${y2 - d} ${x2} ${y2}`;
  }
  const d = 0.4 * (x2 - x1);
  return `M ${x1} ${y1} C ${x1 + d} ${y1} ${x2 - d} ${y2} ${x2} ${y2}`;
}
---

<figure class="cmap figure">
  <svg
    viewBox="0 0 960 800"
    role="img"
    aria-label="Concept map of the smolml compendium: concepts wired by dependency feed the experiment log, with every experiment hung off it below in two phase rows — Space-B byte prediction and Space-C control plus the finding. Dashed-border nodes are negative results, logged as first-class data."
    class="cmap-svg"
  >
    <defs>
      <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" fill="#6f6650"></path>
      </marker>
    </defs>

    {
      edges.map((e) => (
        <path
          d={edgePath(byId[e.from], byId[e.to])}
          fill="none"
          class={e.dashed ? "cmap-edge dashed" : "cmap-edge"}
          marker-end="url(#arrow)"
        />
      ))
    }

    {
      nodes.map((n) => {
        const inner = (
          <g class={`cmap-node role-${n.role ?? "default"}`}>
            <rect x={n.x - n.w / 2} y={n.y - H / 2} width={n.w} height={H} rx="9" />
            <text x={n.x} y={n.y + 4} text-anchor="middle">
              {n.label}
            </text>
          </g>
        );
        return n.href ? (
          <a href={n.href} aria-label={n.label}>
            {inner}
          </a>
        ) : (
          inner
        );
      })
    }

    {/* experiment buses: the log indexes every experiment, on two phase rows */}
    <line x1={TRUNK_X} y1={byId.exp.y + H / 2} x2={TRUNK_X} y2={BYTE_BUS_Y} class="cmap-edge" />
    <line x1={CONN_X} y1={BYTE_BUS_Y} x2={byteMaxX} y2={BYTE_BUS_Y} class="cmap-edge" />
    <line x1={CONN_X} y1={BYTE_BUS_Y} x2={CONN_X} y2={CTRL_BUS_Y} class="cmap-edge" />
    <line x1={CONN_X} y1={CTRL_BUS_Y} x2={ctrlMaxX} y2={CTRL_BUS_Y} class="cmap-edge" />
    {/* row labels */}
    <text x={CONN_X - 4} y={BYTE_BUS_Y - 8} class="cmap-row-label" text-anchor="start">Space-B · bytes</text>
    <text x={CONN_X - 4} y={CTRL_BUS_Y - 8} class="cmap-row-label" text-anchor="start">Space-C · control</text>
    {
      allLeaves.map((n) => (
        <line x1={n.x} y1={n.busY} x2={n.x} y2={n.leafY - H / 2} class="cmap-edge" marker-end="url(#arrow)" />
      ))
    }
    {
      allLeaves.map((n) => (
        <a href={n.href} aria-label={n.label}>
          <g class={`cmap-node cmap-leaf role-${n.role ?? "default"}${n.negative ? " negative" : ""}`}>
            <rect x={n.x - LEAF_W / 2} y={n.leafY - H / 2} width={LEAF_W} height={H} rx="9" />
            <text x={n.x} y={n.leafY + 4} text-anchor="middle">
              {n.label}
            </text>
          </g>
        </a>
      ))
    }

    {/* legend */}
    <g class="cmap-legend">
      <rect x={LG_X} y={LG_Y} width={474} height={164} rx="10" class="cmap-legend-box" />
      <text x={LG_X + 16} y={LG_Y + 24} class="cmap-legend-title">legend — node border = role</text>
      {
        legendRoles.map((r, i) => {
          const col = i < 4 ? 0 : 1;
          const row = i % 4;
          const sx = LG_X + 16 + col * 218;
          const sy = LG_Y + 44 + row * 21;
          return (
            <>
              <rect x={sx} y={sy} width={13} height={13} rx="3" class={`cmap-sw sw-${r.role}`} />
              <text x={sx + 20} y={sy + 11} class="cmap-legend-item">
                {r.label}
              </text>
            </>
          );
        })
      }
      {/* encoding keys */}
      <rect x={LG_X + 16} y={LG_Y + 130} width={13} height={13} rx="3" class="cmap-sw sw-accent" />
      <text x={LG_X + 36} y={LG_Y + 141} class="cmap-legend-item">goal · log · finding</text>
      <rect x={LG_X + 234} y={LG_Y + 130} width={13} height={13} rx="3" class="cmap-sw sw-neg" />
      <text x={LG_X + 254} y={LG_Y + 141} class="cmap-legend-item">dashed = negative (logged as data)</text>
    </g>
  </svg>
  <figcaption class="figcaption">
    The dependency spine: the goal flows into three pillars, which feed the prequential protocol, the
    mechanisms (fast-weight memory, predictive coding, the context-mixing reference) and the in-context
    control rung &mdash; all indexed by the experiment log, with every experiment hung off it below in two
    phase rows (Space-B byte prediction; Space-C control &#43; the finding). <strong>Dashed, muted
    boxes are negatives</strong> &mdash; candidates that were Pareto-hollow, killed, or lost on their
    metric (A.1, B.1, B.5, C.A.1); failures are first-class data. Dashed edges are feedback / log links.
    Every box is a page &mdash; click through.
  </figcaption>
</figure>

<style>
  .cmap-svg {
    width: 100%;
    height: auto;
    display: block;
    font-family: var(--font-mono);
  }
  .cmap-edge {
    stroke: #6f6650;
    stroke-width: 1.4;
  }
  .cmap-edge.dashed {
    stroke-dasharray: 5 5;
    stroke: #5a5240;
  }
  .cmap-node rect {
    fill: var(--ink-2);
    stroke: var(--accent-deep);
    stroke-width: 1.4;
    transition:
      fill 0.15s ease,
      stroke 0.15s ease;
  }
  .cmap-node text {
    fill: var(--paper);
    font-size: 12.5px;
  }
  .cmap-leaf text {
    font-size: 11px;
    fill: var(--paper-dim);
  }
  /* negatives: dashed, muted border + a darker fill — failures are first-class */
  .cmap-leaf.negative rect {
    stroke-dasharray: 4 3;
    fill: var(--ink-1);
  }
  .cmap-leaf.negative text {
    fill: var(--muted);
  }
  .cmap-row-label {
    fill: var(--faint);
    font-size: 10px;
    letter-spacing: 0.04em;
  }
  .role-reference rect {
    stroke: var(--c-reference);
  }
  .role-fast_weight rect {
    stroke: var(--c-fast);
  }
  .role-transformer rect {
    stroke: var(--c-transformer);
  }
  .role-pc rect {
    stroke: var(--c-pc);
  }
  .role-warm rect {
    stroke: var(--c-warm);
  }
  .role-reservoir rect {
    stroke: var(--c-reservoir);
  }
  .role-chemotaxis rect {
    stroke: var(--c-chemo);
  }
  .role-column_mix rect {
    stroke: var(--c-column);
  }
  .role-accent rect {
    stroke: var(--accent);
  }
  a:hover .cmap-node rect {
    fill: var(--ink-3);
    stroke: var(--accent);
  }
  a {
    border: none;
    cursor: pointer;
  }
  a:hover .cmap-node text {
    fill: #fff7e8;
  }
  /* legend */
  .cmap-legend-box {
    fill: var(--ink-1);
    stroke: var(--line);
    stroke-width: 1;
  }
  .cmap-legend-title {
    fill: var(--paper-dim);
    font-size: 11px;
    letter-spacing: 0.04em;
  }
  .cmap-legend-item {
    fill: var(--muted);
    font-size: 10.5px;
  }
  .cmap-sw {
    stroke: var(--ink);
    stroke-width: 0.5;
  }
  .sw-reference {
    fill: var(--c-reference);
  }
  .sw-fast_weight {
    fill: var(--c-fast);
  }
  .sw-warm {
    fill: var(--c-warm);
  }
  .sw-pc {
    fill: var(--c-pc);
  }
  .sw-reservoir {
    fill: var(--c-reservoir);
  }
  .sw-chemotaxis {
    fill: var(--c-chemo);
  }
  .sw-column_mix {
    fill: var(--c-column);
  }
  .sw-transformer {
    fill: var(--c-transformer);
  }
  .sw-accent {
    fill: var(--accent);
  }
  .sw-neg {
    fill: var(--ink-2);
    stroke: var(--muted);
    stroke-width: 1.2;
    stroke-dasharray: 3 2;
  }
</style>
